;------------------------------------------------------------------------------
/OBJ    ;Objetos
;num    starts at   weight    c w  5 4 3 2 1 0 9 8 7 6 5 4 3 2 1 0    noun   adjective
/0      CARRIED       1       _ _  _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _    LINTER  _
;------------------------------------------------------------------------------
/PRO 0   

; Este proceso es el primero en ser ejecutado por DAAD, y asŪ contiene una primera entrada que
; salta al proceso que inicializa objetos, flags, etc. y luego cada vez que es llamado, y el
; jugador ya no estŠ en la localidad 0, se encarga de mostrar el grŠfico y texto de la localidad
; actual, si procede,  y saltar al proceso 1 donde estŠ el sistema que pide ůrdenes al jugador.



> _       _     AT      0               ; Iniciando el juego
                PROCESS 6               ; El proceso de inicializaciůn
                

> _       _     WINAT 13 0              ; por defecto, la ventana de texto estŠ en la parte inferior
                #ifdef "splitModeOn"    ; si soporta split screen, activarla
                    XSPLITSCR 1
                    #ifdef "cpc"
                    WINAT 14 0           ;  y si es CPC, la ponemos un poco mŠs abajo para evitar problemas en la zona de cambio de modo
                    #endif
                #endif
                WINDOW 1
                WINSIZE 25 127


> _       _     WINDOW  0               ; Ventana de grŠficos
                CLEAR   fDarkF          ; Asume que hay luz
                NOTZERO 0
                ABSENT  0
                SET     fDarkF          ; Oscuro
                

                
> _       _     ZERO fDarkF
                PICTURE @fPlayer        ; Si hay una imagen, cargarla
                DISPLAY 0
                SKIP $pictureOK

; Si llegamos aquŪ, no habŪa grŠfico para esta localidad, ponemos texto a pantalla completa
> _       _     #ifdef "splitModeOn"                  
                    CLS                     ; Si era modo split, tenemos que limpiar la pantalla
                    XSPLITSCR 0             ; y quitar el modo split 
                #endif
                WINDOW 1
                WINAT 0 0               ; Si no hay imagen, nos ponemos a pantalla completa de texto
                WINSIZE 25 127
                CLS

$pictureOK

> _       _     WINDOW 1                 ; Ventana de texto
                NOTZERO fDarkF           ; Oscuro
                SYSMESS 0

> _       _     ZERO    fDarkF
                DESC   @fPlayer        

> _       _     PROCESS 3

; Ahora usamos el proceso 1 como el bucle principal del juego. Un retorno desde
; aquŪ significa el fin del juego

> _       _     PROCESS 1

;------------------------------------------------------------------------------
/PRO 1

; Este proceso se encarga de ir pidiendo ůrdenes al jugador e ir ejecutŠndolas,
; ya sea como ůrdenes, o como movimientos en las distintas direcciones.

> _       _     PROCESS 4               ; Lo que en el PAW era el proceso 2

> _       _     PARSE   0               ; Toma sentencia lůgica del buffer
                PROCESS 2               ; Sentencia no vŠlida o timeout
                REDO

> _       _     EQ      fTurns   255     ; El valor mŠximo de un byte
                PLUS    fTurnsHi   1
                CLEAR   fTurns
                SKIP    1

> _       _     PLUS    fTurns   1

> _       _     PROCESS 5               ; La antigua tabla de respuestas
                ISDONE                  ; Ha hecho algo?
                REDO                    ; SŪ≠: pedimos otra orden del jugador

> _       _     MOVE    fPlayer         ; No: intentamos mover al jugador
                CLS
                RESTART                 ; Lo movimos: salta al principio de PRO 0

> _       _     NEWTEXT
                LT      fVerb    14
                SYSMESS 7
                REDO

> _       _     SYSMESS 8
                REDO


;------------------------------------------------------------------------------
/PRO 2

; Este pequeŮo proceso se encarga de dar una respuesta diferente al jugador dependiendo de si
; ha ocurrido un timeout, o si lo que ha tecleado es ininteligible para el parser.

> _       _     HASAT TIMEOUT
                SYSMESS 35
                DONE

> _       _     SYSMESS 6               ; No te entiendo

;------------------------------------------------------------------------------
/PRO 3

; Este proceso se ejecuta justo despuťs de mostrar la descripciůn de una localidad, y se encarga de mostrar la lista de objetos
; que hay en ella, si los hay. Puedes aŮadir aquŪ entradas que muestren texto o hagan cosas cuando el jugador llega a determinada 
; localidad. Para los que venŪs de PAW, es el equivalente al proceso 1. Ver las entradas de ejemplo:

; EJEMPLOS:
; > _ _  AT 2                                       ; ŅEstamos en la localidad de la puerta?
;        NOTZERO fPuertaAbierta                     ; ŅEstŠ la puerta abierta? (esto requiere que en otro sitio modifiquemos el flag fPuertaAbierta)
;        MESSAGE "La puerta estŠ abierta. "         ; Mostramos texto
;
; > _ _  AT 17                                      ; ŅEstamos en la localidad con atmůsfera irrespirable?
;        NOTCARRIED oTrajeProtector                 ; ŅNo llevamos el traje?
;        MESSAGE "Te has asfixiado. EstŠs muerto."  ; Mostramos texto
;        END                                        ; ŅJugar de nuevo?


 
; Esta entrada ya viene activa, y es la que se encarga precisamente de mostrar la lista de objetos (si los hay, y no estŠ oscuro)
> _       _     NEWLINE
                ZERO    fDarkF            ; No estŠ oscuro
                LISTOBJ


;------------------------------------------------------------------------------
/PRO 4 

; Este proceso se ejecuta cada turno, despuťs de dar respuesta la orden del jugador. Es ķtil para controlar cosas que puedan 
; pasar pasado un tiempo, o eventos que puedan ocurrir en cualquier momento. Para los que venŪs de PAW, es el equivalente al
; proceso 2. Ver las entradas de ejemplo:

; > _ _   AT 17                                         ; ŅEstamos en la localidad de la atmůsfera irrespirable?
;         MINUS fOxigenoEnTraje 1                       ; Decrementamos en 1 el valor del flag fOxigeno en traje (ha debido ser puesto a un cierto valor antes)
;         ZERO fOxigenoEnTraje                          ; ŅHemos llegado a cero? ŅEl ůxigeno se ha acabado?
;         MESSAGE "No puedes respirar. EstŠs muerto."   ; Mostramos texto
;         END                                           ; ŅJugar de nuevo?
;
; > _ _   AT 4                                          ; ŅEstamos en el bosque?
;         CHANCE 10                                     ; Esta condiciůn se cumple un 10% de las veces
;         MESSAGE "Oyes algo que repta entre las hojas" ; Mostrar texto


/PRO 5 

; En este proceso se da respuesta a la ordenes del jugador, por lo que las entradas suelen
; tener verbo y nombre, o al menos verbo. Las ůrdenes del jugador ejecutarŠn cada entrada
; si coinciden con las palabras indicadas en cada una. Ten en cuenta que se ejecutan en 
; el orden en el que estŠn en el fichero, por lo que las respuestŠs mŠs genťricas deben
; detrŠs de las mŠs especŪficas. Para los que venŪs de PAW, es el equivalente a la tabla 
; de respuestas.


> I       _     SYSMESS 9
                LISTAT  CARRIED
                SYSMESS 10
                LISTAT  WORN
                DONE

> COGER   TODO  DOALL   HERE                
> COGER   _     AUTOG
                DONE

> DEJAR   TODO  DOALL   CARRIED
> DEJAR   _     AUTOD
                DONE

> QUITAR  TODO  DOALL   WORN
> QUITAR  _     AUTOR
                DONE

> PONER   TODO  DOALL   CARRIED
> PONER   _     AUTOW
                DONE

> R       _     CLS
                RESTART

> FIN     _     QUIT
                END

> FIN     _     DONE                    

> SAVE    _     SAVE 0
                CLS
                RESTART

> LOAD    _     LOAD   0
                CLS
                RESTART

> RAMSA   _     RAMSAVE
                CLS
                RESTART

> RAMLO   _     RAMLOAD 255                             ;Reload all flags
                CLS
                RESTART

> MIRAR   _     CLS
            RESTART

/PRO 6 ; Inicializaciůn

> _       _     
                WINDOW  0
                WINAT 0 0
                WINSIZE 25 128
                CLS
                WINDOW  1               ; Pantalla de texto a media altura
                WINAT 14 0
                WINSIZE 25 128
                WINDOW   0
                PICTURE 0 
                DISPLAY 0
                SKIP $picture0OK

#ifndef "splitModeON"                  
>  _     _      WINDOW  1                   ; Si llegamos aquŪ, el grŠfico 000 no estaba
                WINAT 0 0              
                WINSIZE 25 128             ; Ponemos la pantalla a full screen, salvo si  es split mode
#endif

$picture0OK
> _       _     WINDOW 1
                DESC    0               ; Texto Introducciůn
                ANYKEY
                CLS
                SET   255             

$initLoop                
> _       _     MINUS   255 1          ; Pone a cero todos los flags
                NOTEQ   255  fGFlags  ; menos GFlags!!!
                CLEAR   @255

> _       _     NOTZERO 255             
                SKIP    $initLoop

> _       _     RESET                     ; Objetos a su loc. inicial / Flag 1
                LET     fStrength 10
                LET     fMaxCarr 4
                SET     fCPronounNoun
                SET     fCPronounAdject
                LET     fObjectsCarried   NUM_CARRIED 
                LET     fObjFlags 4       ; Activar sin terminaciones pronominales para verbos >=240
                GOTO    1                 ; Primera localidad del juego
/END